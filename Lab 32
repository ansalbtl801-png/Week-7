import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
df = pd.read_csv("day32_relationships.csv")
sns.scatterplot(data=df, x="feature1", y="outcome", alpha=0.5)
plt.title("Outcome vs feature1 — Basic scatterplot")
plt.show()
sns.relplot(data=df, x="feature1", y="outcome", alpha=0.5)
plt.show()
